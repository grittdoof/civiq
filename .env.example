# ═══════════════════════════════════════════════════
# GoCiviQ — Variables d'environnement (template)
# ═══════════════════════════════════════════════════
# Copier ce fichier en .env.local et remplir les valeurs
# Ne JAMAIS committer .env.local (déjà dans .gitignore)

# ─── Supabase ───
# Récupérer depuis https://supabase.com/dashboard → projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ───
# URL absolue de la prod (utilisée pour les magic links serveur)
NEXT_PUBLIC_SITE_URL=https://votre-domaine.vercel.app
NEXT_PUBLIC_APP_NAME=GoCiviQ

# ─── Web Push (notifications module Tickets) ───
# Générer avec : npx web-push generate-vapid-keys --json
# Public exposée au client (subscribe), privée serveur uniquement (send)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Email de contact obligatoire pour Web Push (mailto:)
VAPID_SUBJECT=mailto:contact@gociviq.fr

# ─── Optionnel ───
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=gocviq.fr
